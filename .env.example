# Club Commerce WhatsApp Agent — W2 local config
# Copy to .env locally. Never commit real secrets.

# CRM Bridge W1
CRM_API_URL=http://127.0.0.1:4173
CRM_API_KEY=
AGENT_API_KEY=

# AI provider for future W3/W4
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
AI_QUALIFICATION_MIN_SCORE=70
AI_QUALIFICATION_TEMPLATE=hello_world
AI_QUALIFICATION_LANGUAGE=es

# WhatsApp provider. Use mock locally, meta when configuring Cloud API.
WHATSAPP_PROVIDER=mock
# Optional experimental provider:
# WHATSAPP_PROVIDER=web_session
WEB_SESSION_BRIDGE_URL=http://127.0.0.1:3100
WEB_SESSION_BRIDGE_API_KEY=
WEB_SESSION_DEFAULT_SESSION_ID=
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=agentkit-verify
META_APP_SECRET=
META_GRAPH_VERSION=v20.0

# Server
PORT=8000
ENVIRONMENT=development
AGENT_NAME=Club Commerce AI
BUSINESS_NAME=Club Commerce
MEMORY_PATH=./agent_memory.json
